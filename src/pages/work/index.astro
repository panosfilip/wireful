---
import Base from "../../layouts/Base.astro";
import CaseCard from "../../components/CaseCard.astro";
import { caseStudies } from "../../data/caseStudies";
import { site } from "../../data/site";
import { projectTagDefinitions, type ProjectTag } from "../../data/projectTags";

// Editorial ordering: featured first, then live/published work with real media,
// then drafts, then the long tail. Array order breaks ties (stable sort).
const rank = (status: string) => (status === "published" ? 0 : status === "draft" ? 1 : 2);
const hasMedia = (cs: (typeof caseStudies)[number]) =>
  cs.cover.type === "video" || (cs.cover.type === "image" && !!cs.cover.src) ? 0 : 1;

const allWork = [...caseStudies].sort((a, b) => {
  const fa = a.featured ?? Infinity;
  const fb = b.featured ?? Infinity;
  if (fa !== fb) return fa - fb;
  if (rank(a.status) !== rank(b.status)) return rank(a.status) - rank(b.status);
  return hasMedia(a) - hasMedia(b);
});

const featuredWork = allWork.filter((cs) => cs.featured != null).slice(0, 3);

const projectTags = Object.keys(projectTagDefinitions) as ProjectTag[];
const filterGroups = [
  { key: "discipline", label: "Work type" },
  { key: "method", label: "Method" },
  { key: "context", label: "Context" },
].map((group) => ({
  ...group,
  tags: projectTags.filter((tag) => projectTagDefinitions[tag].group === group.key),
}));
---

<Base title={`Work | ${site.name}`}>
  <section class="hero hero-inner">
    <div class="hero-media" aria-hidden="true" data-parallax>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="media/work-hero-poster.jpg"
        src="media/work-hero-bg.mp4"></video>
    </div>
    <div class="container">
      <h1 data-intro style="--intro: 1">Selected UI, web, and <span class="title-keyword">brand work</span>.</h1>
      <p class="lead" data-intro style="--intro: 2">
        Websites, Figma UI, brand systems, WordPress-ready pages, campaign assets, product
        visuals, AI-assisted design workflows, and design consulting.
      </p>
      <div class="hero-actions" data-intro style="--intro: 3">
        <a href="contact" class="btn" data-overlay-trigger data-magnetic>Start a project</a>
        <a href="docs/panagiotis-filippaios-portfolio.pdf" class="btn btn-ghost">
          Portfolio PDF
        </a>
      </div>
    </div>
  </section>

  <script>
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const heroVideo = document.querySelector<HTMLVideoElement>(".hero-media video");
      if (heroVideo) {
        heroVideo.removeAttribute("autoplay");
        heroVideo.pause();
      }
    }
  </script>

  {
    featuredWork.length > 0 && (
      <section class="section section--featured">
        <div class="container">
          <div class="section-head" data-reveal>
            <div>
              <h2>Featured <span class="title-keyword">case studies</span>.</h2>
              <p class="section-kicker">
                A few recent, live projects — public-sector redesigns, animated front-end
                builds, and brand work. The full archive, with filters, is below.
              </p>
            </div>
          </div>
          <div class="work-featured-grid" data-reveal>
            {featuredWork.map((cs) => (
              <CaseCard cs={cs} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2>All <span class="title-keyword">work</span>.</h2>
          <p class="section-kicker">
            National service portals, government redesigns, campaign work, and independent
            concepts. Filter by type, method, or context. More screenshots are added as they
            are cleared for publication.
          </p>
        </div>
      </div>
      <div class="work-filter" id="taxonomy" data-work-filter data-reveal>
        <div class="work-filter-groups">
          {
            filterGroups.map((group) => (
              <div class="work-filter-group" data-dropdown>
                <button
                  class="work-filter-trigger"
                  type="button"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  data-dropdown-trigger
                  data-group={group.key}>
                  <span class="work-filter-trigger__group">{group.label}</span>
                  <span class="work-filter-trigger__value" data-trigger-value />
                  <span class="work-filter-trigger__chevron" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </button>
                <button
                  class="work-filter-clear"
                  type="button"
                  data-dropdown-clear
                  data-group={group.key}
                  aria-label={`Clear ${group.label} filter`}
                  hidden>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                  </svg>
                </button>
                <div class="work-filter-menu" role="listbox" aria-label={group.label} data-dropdown-menu hidden>
                  {group.tags.map((tag) => {
                    const definition = projectTagDefinitions[tag];
                    return (
                      <button
                        class={`work-filter-button work-filter-button--${definition.tone}`}
                        type="button"
                        role="option"
                        aria-selected="false"
                        data-filter-group={group.key}
                        data-filter-value={tag}
                        data-tone={definition.tone}
                        aria-pressed="false">
                        <span class="work-filter-mark" aria-hidden="true">{definition.mark}</span>
                        <span>{definition.label}</span>
                      </button>
                    );
                  })}
                </div>
              </div>
            ))
          }
        </div>
        <div class="work-filter-status">
          <button class="work-filter-reset" type="button" data-filter-reset>Show all work</button>
          <p data-filter-status aria-live="polite"></p>
        </div>
      </div>
      <div class="case-grid" data-filter-grid>
        {
          allWork.map((cs) => (
            <div class="work-filter-item" data-filter-item data-tags={cs.tags.join(" ")}>
              <CaseCard cs={cs} />
            </div>
          ))
        }
      </div>
      <p class="work-empty" data-filter-empty hidden>
        No projects match those filters yet.
        <button type="button" data-filter-reset>Clear filters</button>
      </p>
    </div>
  </section>

  <script>
    const filterRoot = document.querySelector<HTMLElement>("[data-work-filter]");

    if (filterRoot) {
      const filterButtons = Array.from(
        filterRoot.querySelectorAll<HTMLButtonElement>("[data-filter-group]"),
      );
      const resetButtons = Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-filter-reset]"),
      );
      const dropdowns = Array.from(filterRoot.querySelectorAll<HTMLElement>("[data-dropdown]"));
      const filterStatus = filterRoot.querySelector<HTMLParagraphElement>("[data-filter-status]");
      const emptyState = document.querySelector<HTMLElement>("[data-filter-empty]");
      const workItems = Array.from(document.querySelectorAll<HTMLElement>("[data-filter-item]"));
      const activeFilters = new Map<string, string>();

      // Map every filter value to its group so a shared ?tag= URL can be restored.
      const groupForValue = new Map<string, string>();
      filterButtons.forEach((button) => {
        groupForValue.set(button.dataset.filterValue!, button.dataset.filterGroup!);
      });

      const closeDropdowns = (except?: HTMLElement) => {
        dropdowns.forEach((dd) => {
          if (dd === except) return;
          dd.querySelector<HTMLElement>("[data-dropdown-menu]")!.hidden = true;
          dd.querySelector<HTMLElement>("[data-dropdown-trigger]")!.setAttribute("aria-expanded", "false");
        });
      };

      // Reflect each group's selection in its trigger: swap the group label for
      // the chosen token (circle + name) so the brand mark stays visible.
      const refreshTriggers = () => {
        dropdowns.forEach((dd) => {
          const trigger = dd.querySelector<HTMLElement>("[data-dropdown-trigger]")!;
          const valueEl = dd.querySelector<HTMLElement>("[data-trigger-value]")!;
          const clear = dd.querySelector<HTMLButtonElement>("[data-dropdown-clear]")!;
          const value = activeFilters.get(trigger.dataset.group!);
          const option = value
            ? dd.querySelector<HTMLElement>(`[data-filter-value="${value}"]`)
            : null;

          if (option) {
            valueEl.innerHTML = option.innerHTML;
            valueEl.className = `work-filter-trigger__value work-filter-button--${option.dataset.tone}`;
            trigger.classList.add("is-active");
            clear.hidden = false;
          } else {
            valueEl.innerHTML = "";
            valueEl.className = "work-filter-trigger__value";
            trigger.classList.remove("is-active");
            clear.hidden = true;
          }
        });
      };

      dropdowns.forEach((dd) => {
        const trigger = dd.querySelector<HTMLButtonElement>("[data-dropdown-trigger]")!;
        const menu = dd.querySelector<HTMLElement>("[data-dropdown-menu]")!;
        trigger.addEventListener("click", (event) => {
          event.stopPropagation();
          const willOpen = menu.hidden;
          closeDropdowns(dd);
          menu.hidden = !willOpen;
          trigger.setAttribute("aria-expanded", String(willOpen));
        });
      });

      filterRoot.querySelectorAll<HTMLButtonElement>("[data-dropdown-clear]").forEach((clear) => {
        clear.addEventListener("click", (event) => {
          event.stopPropagation();
          activeFilters.delete(clear.dataset.group!);
          closeDropdowns();
          updateWork();
          syncUrl();
        });
      });

      document.addEventListener("click", () => closeDropdowns());
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeDropdowns();
      });

      const syncUrl = () => {
        const url = new URL(window.location.href);
        const values = Array.from(activeFilters.values());
        if (values.length) {
          url.searchParams.set("tag", values.join(","));
        } else {
          url.searchParams.delete("tag");
        }
        window.history.replaceState({}, "", url);
      };

      const updateWork = () => {
        let visibleCount = 0;

        workItems.forEach((item) => {
          const tags = item.dataset.tags?.split(" ") ?? [];
          const matches = Array.from(activeFilters.values()).every((tag) => tags.includes(tag));
          item.hidden = !matches;
          if (matches) visibleCount += 1;
        });

        filterButtons.forEach((button) => {
          const pressed =
            activeFilters.get(button.dataset.filterGroup!) === button.dataset.filterValue;
          button.setAttribute("aria-pressed", String(pressed));
          button.setAttribute("aria-selected", String(pressed));
        });

        refreshTriggers();

        if (filterStatus) {
          filterStatus.textContent = `${visibleCount} ${visibleCount === 1 ? "project" : "projects"} shown`;
        }
        if (emptyState) emptyState.hidden = visibleCount !== 0;
      };

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const group = button.dataset.filterGroup!;
          const value = button.dataset.filterValue!;

          if (activeFilters.get(group) === value) {
            activeFilters.delete(group);
          } else {
            activeFilters.set(group, value);
          }

          updateWork();
          syncUrl();
        });
      });

      resetButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeFilters.clear();
          updateWork();
          syncUrl();
        });
      });

      // Restore filter state from a shared URL (?tag=web,motion or a single ?tag=web).
      const initialTags = new URLSearchParams(window.location.search).get("tag");
      if (initialTags) {
        initialTags.split(",").forEach((value) => {
          const group = groupForValue.get(value.trim());
          if (group) activeFilters.set(group, value.trim());
        });
      }

      updateWork();
    }
  </script>
</Base>
