---
import Base from "../../layouts/Base.astro";
import PlaceholderVisual from "../../components/PlaceholderVisual.astro";
import CapabilityTags from "../../components/CapabilityTags.astro";
import { caseStudies } from "../../data/caseStudies";
import { site } from "../../data/site";
import { withPlaceholders } from "../../utils/placeholders";

export function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props;
const hasLightbox =
  (cs.gallery?.length ?? 0) > 0 || (cs.cover.type === "image" && !!cs.cover.full);
const index = caseStudies.findIndex((c) => c.slug === cs.slug);
const prev = index > 0 ? caseStudies[index - 1] : caseStudies[caseStudies.length - 1];
const next = index < caseStudies.length - 1 ? caseStudies[index + 1] : caseStudies[0];
---

<Base title={`${cs.title} | ${site.name}`} description={cs.summary}>
  <article>
    <header class="case-hero">
      <div class="container">
        <h1 data-intro style="--intro: 1">{cs.title}</h1>
        <p class="lead" data-intro style="--intro: 2">{cs.summary}</p>
      </div>
    </header>

    <div class="container">
      <div class="case-meta" data-reveal-group>
        <div>
          <h2>Role</h2>
          <ul>{cs.role.map((r) => <li>{r}</li>)}</ul>
        </div>
        <div>
          <h2>Services</h2>
          <ul>{cs.services.map((s) => <li>{s}</li>)}</ul>
        </div>
        <div>
          <h2>Tools</h2>
          <ul>{cs.tools.map((t) => <li>{t}</li>)}</ul>
        </div>
        <div>
          <h2>Capability tokens</h2>
          <CapabilityTags tags={cs.tags} variant="detail" />
        </div>
        <div>
          <h2>Details</h2>
          {cs.year && <p set:html={withPlaceholders(cs.year)} />}
          {cs.clientType && <p>{cs.clientType}</p>}
          {
            cs.liveUrl && (
              <p>
                <a class="case-live-link" href={cs.liveUrl} target="_blank" rel="noopener">
                  Visit live site ↗
                </a>
              </p>
            )
          }
          {
            cs.status === "placeholder" && (
              <p>
                <span class="status-chip">Coming soon</span>
              </p>
            )
          }
        </div>
      </div>

      <figure class="case-cover" data-reveal>
        <div class="case-cover__media">
          {
            cs.cover.type === "video" && cs.cover.src ? (
              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster={cs.cover.poster}
                src={cs.cover.src}
                aria-label={cs.cover.alt}
              />
            ) : cs.cover.type === "image" && cs.cover.src ? (
              cs.cover.full ? (
                <button
                  type="button"
                  class="case-cover__trigger"
                  data-lightbox={cs.cover.full}
                  data-lightbox-alt={cs.cover.caption ? `${cs.cover.caption}: full page` : cs.cover.alt}
                  aria-label={`Open full page: ${cs.cover.caption ?? cs.cover.alt}`}
                >
                  <img src={cs.cover.src} alt={cs.cover.alt} />
                  <span class="case-shot__zoom" aria-hidden="true">Open full page ↗</span>
                </button>
              ) : (
                <img src={cs.cover.src} alt={cs.cover.alt} />
              )
            ) : (
              <PlaceholderVisual motif={cs.cover.motif} alt={cs.cover.alt} />
            )
          }
        </div>
        {cs.cover.type === "image" && cs.cover.caption && (
          <figcaption class="case-shot__caption">{cs.cover.caption}</figcaption>
        )}
      </figure>
      {
        cs.cover.visualPrompt && (
          <p class="visual-note" set:html={withPlaceholders(cs.cover.visualPrompt)} />
        )
      }

      {
        cs.gallery && cs.gallery.length > 0 && (
          <div class="case-gallery" data-reveal-group>
            {cs.gallery.map((shot) =>
              shot.type === "video" ? (
                <figure class="case-shot" data-reveal>
                  <div class="case-shot__media">
                    <video
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={shot.poster}
                      src={shot.src}
                      aria-label={shot.alt}
                    />
                    <span class="case-shot__badge" aria-hidden="true">Motion</span>
                  </div>
                  {shot.caption && <figcaption class="case-shot__caption">{shot.caption}</figcaption>}
                </figure>
              ) : (
                <figure class="case-shot" data-reveal>
                  <button
                    type="button"
                    class="case-shot__trigger"
                    data-lightbox={shot.full ?? shot.src}
                    data-lightbox-alt={shot.caption ? `${shot.caption}: full page` : shot.alt}
                    aria-label={`Open full page: ${shot.caption ?? shot.alt}`}
                  >
                    <img src={shot.src} alt={shot.alt} loading="lazy" />
                    <span class="case-shot__zoom" aria-hidden="true">Open full page ↗</span>
                  </button>
                  {shot.caption && <figcaption class="case-shot__caption">{shot.caption}</figcaption>}
                </figure>
              )
            )}
          </div>
        )
      }

      <div class="case-body-sections">
        <section aria-label="The problem" class="case-section" data-reveal>
          <h2>Problem</h2>
          <p class="body" set:html={withPlaceholders(cs.problem)} />
        </section>

        {
          cs.sections.map((section) => (
            <section class="case-section" data-reveal>
              <h2>{section.heading}</h2>
              <div>
                <p class="body" set:html={withPlaceholders(section.body)} />
                {section.mediaPlaceholder && (
                  <div class="media-drop" set:html={withPlaceholders(section.mediaPlaceholder)} />
                )}
              </div>
            </section>
          ))
        }

        {
          cs.outcomes && cs.outcomes.length > 0 && (
            <section class="case-section" data-reveal>
              <h2>Outcomes</h2>
              <ul class="body">
                {cs.outcomes.map((o) => (
                  <li set:html={withPlaceholders(o)} />
                ))}
              </ul>
            </section>
          )
        }
      </div>

      <nav class="case-pager" aria-label="More case studies">
        <a href={`work/${prev.slug}/`} class="prev">
          <span class="dir">← Previous</span>
          <span class="name">{prev.title}</span>
        </a>
        <a href={`work/${next.slug}/`} class="next">
          <span class="dir">Next →</span>
          <span class="name">{next.title}</span>
        </a>
      </nav>
    </div>
  </article>

  {
    hasLightbox && (
      <div class="lightbox" id="lightbox" hidden>
        <div class="lightbox__backdrop" data-lightbox-close />
        <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="Full page preview">
          <button type="button" class="lightbox__close" data-lightbox-close aria-label="Close">
            Close ✕
          </button>
          <div class="lightbox__scroll">
            <img class="lightbox__img" id="lightbox-img" src="" alt="" />
          </div>
        </div>
      </div>
    )
  }
</Base>

<script>
  const lightbox = document.getElementById("lightbox");
  if (lightbox) {
    const img = document.getElementById("lightbox-img") as HTMLImageElement;
    const scroll = lightbox.querySelector(".lightbox__scroll");
    let lastTrigger: HTMLElement | null = null;

    const open = (src: string, alt: string, trigger: HTMLElement) => {
      lastTrigger = trigger;
      img.src = src;
      img.alt = alt;
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
      if (scroll) scroll.scrollTop = 0;
      requestAnimationFrame(() => lightbox.classList.add("is-open"));
    };

    const close = () => {
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      window.setTimeout(() => {
        lightbox.hidden = true;
        img.src = "";
      }, 200);
      if (lastTrigger) lastTrigger.focus();
    };

    document.querySelectorAll<HTMLElement>("[data-lightbox]").forEach((btn) => {
      btn.addEventListener("click", () => {
        open(
          btn.dataset.lightbox || "",
          btn.dataset.lightboxAlt || "",
          btn,
        );
      });
    });

    lightbox.querySelectorAll("[data-lightbox-close]").forEach((el) => {
      el.addEventListener("click", close);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.hidden) close();
    });
  }
</script>
