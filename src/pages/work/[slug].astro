---
import Base from "../../layouts/Base.astro";
import PlaceholderVisual from "../../components/PlaceholderVisual.astro";
import CapabilityTags from "../../components/CapabilityTags.astro";
import CaseCard from "../../components/CaseCard.astro";
import CaseFlowShowcase from "../../components/CaseFlowShowcase.astro";
import { caseStudies } from "../../data/caseStudies";
import { site } from "../../data/site";
import { withPlaceholders } from "../../utils/placeholders";
import { byFeaturedThenStatus } from "../../utils/workOrder";

export function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props;
const hasLightbox =
  (cs.gallery?.length ?? 0) > 0 ||
  (cs.cover.type === "image" && !!cs.cover.full) ||
  !!cs.flowShowcase;

// Consecutive gallery shots sharing a `group` label render as separate grids,
// each under its own small heading. Ungrouped shots form unlabeled grids.
type GalleryShot = NonNullable<typeof cs.gallery>[number];
const galleryGroups: Array<{ label?: string; items: GalleryShot[] }> = [];
for (const shot of cs.gallery ?? []) {
  const last = galleryGroups[galleryGroups.length - 1];
  if (last && last.label === shot.group) last.items.push(shot);
  else galleryGroups.push({ label: shot.group, items: [shot] });
}

// Related work: the projects that share the most tags, so the footer keeps
// people inside relevant work instead of walking the array in order.
const related = caseStudies
  .filter((c) => c.slug !== cs.slug)
  .map((c) => ({ c, shared: c.tags.filter((t) => cs.tags.includes(t)).length }))
  .filter((x) => x.shared > 0)
  .sort((a, b) => b.shared - a.shared || byFeaturedThenStatus(a.c, b.c))
  .slice(0, 3)
  .map((x) => x.c);

// Absolute URLs for social/link previews and structured data.
const coverImage = cs.cover.type === "video" ? cs.cover.poster : cs.cover.src;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const absImage = coverImage
  ? new URL(`${import.meta.env.BASE_URL}/${coverImage}`, Astro.site).href
  : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: cs.title,
  description: cs.summary,
  url: pageUrl,
  ...(absImage ? { image: absImage } : {}),
  ...(cs.liveUrl ? { sameAs: cs.liveUrl } : {}),
  ...(cs.clientType ? { about: cs.clientType } : {}),
  creator: { "@type": "Person", name: site.owner },
  keywords: cs.tags.join(", "),
};
---

<Base title={`${cs.title} | ${site.name}`} description={cs.summary} image={coverImage}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <article>
    <header class="case-hero">
      <div class="container">
        <h1 data-intro style="--intro: 1">{cs.title}</h1>
        <p class="lead" data-intro style="--intro: 2">{cs.summary}</p>
      </div>
    </header>

    <div class="container">
      <div class="case-meta" data-reveal-group>
        <div>
          <h2>Role</h2>
          <ul>{cs.role.map((r) => <li>{r}</li>)}</ul>
        </div>
        <div>
          <h2>Engagement</h2>
          {
            cs.engagement ? (
              <p>{cs.engagement}</p>
            ) : (
              <p set:html={withPlaceholders("[ADD ENGAGEMENT]")} />
            )
          }
        </div>
        <div>
          <h2>Services</h2>
          <ul>{cs.services.map((s) => <li>{s}</li>)}</ul>
        </div>
        <div>
          <h2>Tools</h2>
          <ul>{cs.tools.map((t) => <li>{t}</li>)}</ul>
        </div>
        <div>
          <h2>Capability tokens</h2>
          <CapabilityTags tags={cs.tags} perRow={2} />
        </div>
        <div>
          <h2>Details</h2>
          {cs.year && <p set:html={withPlaceholders(cs.year)} />}
          {cs.clientType && <p>{cs.clientType}</p>}
          {
            cs.liveLinks?.length ? (
              cs.liveLinks.map((link) => (
                <p>
                  <a class="case-live-link" href={link.url} target="_blank" rel="noopener">
                    {link.label} ↗
                  </a>
                </p>
              ))
            ) : cs.liveUrl ? (
              <p>
                <a class="case-live-link" href={cs.liveUrl} target="_blank" rel="noopener">
                  Visit live site ↗
                </a>
              </p>
            ) : null
          }
          {
            cs.status === "placeholder" && (
              <p>
                <span class="status-chip">Coming soon</span>
              </p>
            )
          }
        </div>
      </div>

      <figure class="case-cover" data-reveal>
        <div class="case-cover__media">
          {
            cs.cover.type === "video" && cs.cover.src ? (
              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster={cs.cover.poster}
                src={cs.cover.src}
                aria-label={cs.cover.alt}
              />
            ) : cs.cover.type === "image" && cs.cover.src ? (
              cs.cover.full ? (
                <button
                  type="button"
                  class="case-cover__trigger"
                  data-lightbox={cs.cover.full}
                  data-lightbox-alt={cs.cover.caption ? `${cs.cover.caption}: full page` : cs.cover.alt}
                  aria-label={`Open full page: ${cs.cover.caption ?? cs.cover.alt}`}
                >
                  <img src={cs.cover.src} alt={cs.cover.alt} />
                  <span class="case-shot__zoom" aria-hidden="true">Open full page ↗</span>
                </button>
              ) : (
                <img src={cs.cover.src} alt={cs.cover.alt} />
              )
            ) : (
              <PlaceholderVisual motif={cs.cover.motif} alt={cs.cover.alt} />
            )
          }
        </div>
        {cs.cover.type === "image" && cs.cover.caption && (
          <figcaption class="case-shot__caption">{cs.cover.caption}</figcaption>
        )}
      </figure>
      {
        cs.cover.visualPrompt && (
          <p class="visual-note" set:html={withPlaceholders(cs.cover.visualPrompt)} />
        )
      }

      {!cs.flowShowcase && galleryGroups.map((group) => (
        <section class="case-gallery-group">
          {group.label && <h2 class="case-gallery__heading" data-reveal>{group.label}</h2>}
          <div class="case-gallery" data-reveal-group>
            {group.items.map((shot) =>
              shot.type === "video" ? (
                <figure class="case-shot" data-reveal>
                  <div class="case-shot__media">
                    <video
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={shot.poster}
                      src={shot.src}
                      aria-label={shot.alt}
                    />
                    <span class="case-shot__badge" aria-hidden="true">Motion</span>
                  </div>
                  {shot.caption && <figcaption class="case-shot__caption">{shot.caption}</figcaption>}
                </figure>
              ) : (
                <figure class="case-shot" data-reveal>
                  <button
                    type="button"
                    class="case-shot__trigger"
                    data-lightbox={shot.full ?? shot.src}
                    data-lightbox-alt={shot.caption ? `${shot.caption}: full page` : shot.alt}
                    aria-label={`Open full page: ${shot.caption ?? shot.alt}`}
                  >
                    <img src={shot.src} alt={shot.alt} loading="lazy" />
                    <span class="case-shot__zoom" aria-hidden="true">Open full page ↗</span>
                  </button>
                  {shot.caption && <figcaption class="case-shot__caption">{shot.caption}</figcaption>}
                </figure>
              )
            )}
          </div>
        </section>
      ))}

      {cs.flowShowcase ? <CaseFlowShowcase cs={cs} /> : <div class="case-body-sections">
        <section aria-label="The problem" class="case-section" data-reveal>
          <h2>Problem</h2>
          <p class="body" set:html={withPlaceholders(cs.problem)} />
        </section>

        {
          cs.sections.map((section) => (
            <section class="case-section" data-reveal>
              <h2>{section.heading}</h2>
              <div>
                <p class="body" set:html={withPlaceholders(section.body)} />
                {section.mediaPlaceholder && (
                  <div class="media-drop" set:html={withPlaceholders(section.mediaPlaceholder)} />
                )}
              </div>
            </section>
          ))
        }

        {
          cs.outcomes && cs.outcomes.length > 0 && (
            <section class="case-section" data-reveal>
              <h2>Outcomes</h2>
              <ul class="body">
                {cs.outcomes.map((o) => (
                  <li set:html={withPlaceholders(o)} />
                ))}
              </ul>
            </section>
          )
        }
      </div>}

      {
        related.length > 0 && (
          <section class="case-related" aria-label="Related work" data-reveal-group>
            <div class="case-related__head">
              <h2>Related work</h2>
              <a href="work#taxonomy" class="case-related__all">
                All work ↗
              </a>
            </div>
            <div class="case-related__grid">
              {related.map((r) => (
                <CaseCard cs={r} />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </article>

  {
    hasLightbox && (
      <div class="lightbox" id="lightbox" hidden>
        <div class="lightbox__backdrop" data-lightbox-close />
        <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="Full page preview">
          <button type="button" class="lightbox__close" data-lightbox-close aria-label="Close">
            Close ✕
          </button>
          <div class="lightbox__scroll">
            <img class="lightbox__img" id="lightbox-img" src="" alt="" />
          </div>
          <div class="lightbox__hint" id="lightbox-hint" aria-hidden="true">
            <span>Scroll</span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M6 9l6 6 6-6"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
        </div>
      </div>
    )
  }
</Base>

<script>
  const lightbox = document.getElementById("lightbox");
  if (lightbox) {
    const img = document.getElementById("lightbox-img") as HTMLImageElement;
    const dialog = lightbox.querySelector(".lightbox__dialog") as HTMLElement | null;
    const scroll = lightbox.querySelector(".lightbox__scroll") as HTMLElement | null;
    const hint = document.getElementById("lightbox-hint");
    let lastTrigger: HTMLElement | null = null;

    // Show the "Scroll" hint only when the image overflows the frame and the
    // viewer is still near the top; hide it as soon as they scroll down.
    const updateHint = () => {
      if (!scroll || !hint) return;
      const overflows = scroll.scrollHeight - scroll.clientHeight > 24;
      const atTop = scroll.scrollTop < 24;
      hint.classList.toggle("is-visible", overflows && atTop);
    };

    const open = (src: string, alt: string, trigger: HTMLElement) => {
      lastTrigger = trigger;
      img.src = src;
      img.alt = alt;
      dialog?.classList.toggle(
        "lightbox__dialog--portrait",
        trigger.dataset.lightboxOrientation === "portrait",
      );
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
      if (scroll) scroll.scrollTop = 0;
      hint?.classList.remove("is-visible");
      requestAnimationFrame(() => lightbox.classList.add("is-open"));
    };

    const close = () => {
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      hint?.classList.remove("is-visible");
      window.setTimeout(() => {
        lightbox.hidden = true;
        img.src = "";
        dialog?.classList.remove("lightbox__dialog--portrait");
      }, 200);
      if (lastTrigger) lastTrigger.focus();
    };

    img.addEventListener("load", updateHint);
    scroll?.addEventListener("scroll", updateHint, { passive: true });
    window.addEventListener("resize", updateHint);

    document.querySelectorAll<HTMLElement>("[data-lightbox]").forEach((btn) => {
      btn.addEventListener("click", () => {
        open(
          btn.dataset.lightbox || "",
          btn.dataset.lightboxAlt || "",
          btn,
        );
      });
    });

    lightbox.querySelectorAll("[data-lightbox-close]").forEach((el) => {
      el.addEventListener("click", close);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.hidden) close();
    });
  }
</script>
