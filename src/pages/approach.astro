---
import Base from "../layouts/Base.astro";
import CaseCarousel from "../components/CaseCarousel.astro";
import { approachPillars, principles, site } from "../data/site";
import { caseStudies } from "../data/caseStudies";

const proofWorkSlugs = [
  "my1521-taxpayer-portal",
  "teka-ui-redesign",
  "ppf-growthfund",
  "ekapy-afternoon-surgeries",
  "kifissia-municipality-redesign",
  "eu-regions-week-2025",
];
const proofWork = proofWorkSlugs.map((slug) => caseStudies.find((cs) => cs.slug === slug)!);
const toolkit = [
  {
    label: "Core workspace",
    title: "Interface",
    description: "Structure, components, and screens that show how the interface works.",
    mark: "UI",
    tone: "figma",
    tools: [
      {
        name: "Figma",
        why: "I use it for interface design, responsive layouts, component libraries, and developer handoff.",
      },
      {
        name: "FigJam",
        why: "A shared canvas for mapping flows, organising ideas, and agreeing on the work before screens are designed.",
      },
      {
        name: "Interactive prototypes",
        why: "They make key journeys testable, so the team can review interaction choices before development starts.",
      },
      {
        name: "Design systems & Dev Mode",
        why: "Components and specifications help keep the interface consistent and make handoff clearer.",
      },
    ],
  },
  {
    label: "Visual production",
    title: "Visual production",
    description: "Visual assets for the interface, campaign, or brand.",
    mark: "AD",
    tone: "adobe",
    tools: [
      {
        name: "Adobe Illustrator",
        why: "For icons, vector assets, diagrams, and identity elements used across a product or campaign.",
      },
      {
        name: "Adobe Photoshop",
        why: "For preparing imagery, visual mockups, and campaign assets.",
      },
      {
        name: "Adobe InDesign",
        why: "For longer documents and print material that need to match the digital visual system.",
      },
    ],
  },
  {
    label: "AI copilots",
    title: "AI tools",
    description: "Tools for early research, exploration, and prototyping.",
    mark: "AI",
    tone: "ai",
    tools: [
      {
        name: "Claude",
        why: "For research synthesis, content structure, UX-writing options, and sorting large sets of inputs into starting points.",
      },
      {
        name: "Codex",
        why: "For exploring implementation details, functional prototypes, and the responsive or technical decisions that affect a UI before handoff.",
      },
      {
        name: "Figma Make",
        why: "For turning an early product concept into something a team can discuss and test.",
      },
    ],
  },
  {
    label: "Research and testing",
    title: "Validation",
    description: "Methods for checking design decisions against user needs.",
    mark: "UX",
    tone: "research",
    tools: [
      {
        name: "Information architecture",
        why: "It sets the content, navigation, and user journeys before visual design begins.",
      },
      {
        name: "UX research",
        why: "It brings user needs, behaviour, and constraints into the work instead of relying on assumptions.",
      },
      {
        name: "Usability testing",
        why: "Testing shows where people hesitate, misunderstand a task, or stop before completing it.",
      },
      {
        name: "Think Aloud sessions",
        why: "Hearing what people expect while using a flow helps identify why an interaction is failing.",
      },
      {
        name: "Competitor analysis",
        why: "It shows category patterns, gaps, and conventions worth keeping or avoiding.",
      },
    ],
  },
];
---

<Base title={`Approach | ${site.name}`}>
  <section class="hero hero-inner">
    <div class="hero-media" aria-hidden="true" data-parallax>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="media/approach-hero-poster.jpg"
        src="media/approach-hero-bg.mp4"></video>
    </div>
    <div class="container">
      <h1 data-intro style="--intro: 1">A practical route from brief to <span class="title-keyword">build</span>.</h1>
      <p class="lead" data-intro style="--intro: 2">
        A brand refresh, WordPress site, and product interface need different outputs. The work
        follows the same order: define the problem, set the structure, design in Figma, and
        prepare the files for build and maintenance.
      </p>
    </div>
  </section>

  <!-- Principles -->
  <section class="section" aria-labelledby="principles-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="principles-heading">What I do before the <span class="title-keyword">polish</span>.</h2>
        </div>
      </div>
      <div class="principle-grid" data-reveal-group>
        {
          principles.map((principle, i) => (
            <div class="principle">
              <span class="principle-num">0{i + 1}</span>
              <h3>{principle.title}</h3>
              <p>{principle.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process phases -->
  <section class="section" aria-labelledby="process-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="process-heading">Four phases for <span class="title-keyword">most projects</span>.</h2>
          <p class="section-kicker">
            Each phase produces work you can review and respond to.
          </p>
        </div>
      </div>
      <ol class="process-journey" data-reveal-group aria-label="Project phases">
        {
          approachPillars.map((pillar) => (
            <li class="process-step">
              <div class="process-step-marker" aria-hidden="true">
                <span>{pillar.number}</span>
              </div>
              <div class="process-step-intro">
                <h3>{pillar.title}</h3>
                <p>{pillar.body}</p>
              </div>
              <div class="process-step-work">
                <p class="process-step-detail">{pillar.detail}</p>
                <div class="process-outcome">
                  <span class="process-outcome-label">Outputs</span>
                  <ul class="process-artifact-list" aria-label={`${pillar.title} deliverables`}>
                    {pillar.artifacts.map((artifact) => (
                      <li>
                        <details>
                          <summary>
                            <span class="process-artifact-name">{artifact.name}</span>
                          </summary>
                          <span class="process-artifact-description">{artifact.description}</span>
                        </details>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Toolkit -->
  <section class="section toolkit-section" aria-labelledby="toolkit-heading">
    <div class="container">
      <div class="toolkit-intro" data-reveal>
        <div>
          <h2 id="toolkit-heading">The tools behind<br />the <span class="title-keyword">process</span>.</h2>
          <div class="prose">
            <p>
              I use a focused set of tools to turn the brief into an interface that can be
              reviewed, built, and maintained.
            </p>
          </div>
        </div>
        <p class="toolkit-note"><span>+</span> Open a tool to see how I use it.</p>
      </div>
      <div class="toolkit-grid" data-reveal-group>
        {
          toolkit.map((group) => (
            <article class={`toolkit-card toolkit-card--${group.tone}`}>
              <div class="toolkit-card-top">
                <span class="toolkit-mark" aria-hidden="true">{group.mark}</span>
              </div>
              <span class="toolkit-label">{group.label}</span>
              <h3>{group.title}</h3>
              <p>{group.description}</p>
              <ul class="toolkit-list">
                {group.tools.map((tool) => (
                  <li>
                    <details>
                      <summary>{tool.name}</summary>
                      <p>{tool.why}</p>
                    </details>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Proof -->
  <section class="section" aria-labelledby="proof-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="proof-heading">The process, in <span class="title-keyword">practice</span>.</h2>
        </div>
        <a href="work" class="section-link">All work <span class="arrow">↗&#xFE0E;</span></a>
      </div>
      <CaseCarousel items={proofWork} label="Public-sector and institutional projects" />
    </div>
  </section>

  <section class="section contact-cta">
    <div class="container">
      <h2 data-reveal>Have a project that needs a <span class="title-keyword">clearer plan</span>?</h2>
      <div class="hero-actions" data-reveal style="--reveal-delay: 1">
        <a href="contact" class="btn" data-overlay-trigger data-magnetic>Discuss a project</a>
        <a href="work" class="btn btn-ghost">See the work first</a>
      </div>
    </div>
  </section>
</Base>
