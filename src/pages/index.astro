---
import Base from "../layouts/Base.astro";
import CaseCard from "../components/CaseCard.astro";
import { caseStudies } from "../data/caseStudies";
import { site, approachPillars, proofPoints, capabilities } from "../data/site";

const featuredWork = caseStudies.find((cs) => cs.slug === "my1521-taxpayer-portal")!;
const homeWorkSlugs = [
  "teka-ui-redesign",
  "ppf-growthfund",
  "ekapy-afternoon-surgeries",
  "kifissia-municipality-redesign",
  "eu-regions-week-2025",
];
const homeWork = homeWorkSlugs.map((slug) => caseStudies.find((cs) => cs.slug === slug)!);
const [headlineBefore, headlineAfter] = site.headline.split("clear");
const marqueeItems = [...capabilities, ...capabilities];
const capabilityDirectory = [
  { mark: "WD", label: "Website design", tone: "violet" },
  { mark: "UI", label: "Product UI", tone: "rose" },
  { mark: "UX", label: "UX research & audits", tone: "amber" },
  { mark: "FI", label: "Figma prototypes", tone: "lime" },
  { mark: "BR", label: "Brand systems", tone: "green" },
  { mark: "CA", label: "Campaign assets", tone: "cyan" },
  { mark: "WP", label: "WordPress & Elementor", tone: "blue" },
  { mark: "AI", label: "AI-assisted workflows", tone: "violet" },
  { mark: "CO", label: "Design consulting", tone: "rose" },
];
---

<Base title={`${site.name} | ${site.owner}, ${site.role}`}>
  <!-- Hero -->
  <section class="hero hero-home">
    <div class="hero-media" aria-hidden="true" data-parallax>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="media/hero-poster.jpg"
        src="media/hero-bg.mp4"></video>
    </div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 data-intro style="--intro: 0">
          {headlineBefore}<span class="title-keyword">clear</span>{headlineAfter}
        </h1>
        <p class="lead" data-intro style="--intro: 1">{site.intro}</p>
        <div class="hero-actions" data-intro style="--intro: 2">
          <a href="contact" class="btn" data-overlay-trigger data-magnetic>Start a project</a>
          <a href="work" class="btn btn-ghost">See selected work</a>
        </div>
      </div>
      <div class="hero-portrait" data-intro style="--intro: 1">
        <img
          src="media/filippaios.webp"
          alt={`Portrait of ${site.fullName}`}
          width="585"
          height="856"
          fetchpriority="high"
        />
        <span class="hero-portrait-tag" aria-hidden="true">that's me</span>
      </div>
    </div>
  </section>

  <!-- Capability marquee -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {marqueeItems.map((item) => <span class="marquee-item">{item}</span>)}
    </div>
  </div>

  <!-- Proof stats -->
  <section class="stat-strip" aria-label="Track record">
    <div class="container">
      <div class="stat-grid" data-reveal-group>
        {
          proofPoints.map((proof) => (
            <div class="stat">
              <strong data-count>{proof.value}</strong>
              <span>{proof.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Offer -->
  <section class="section" id="services" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="services-heading">What I can help you <span class="title-keyword">make</span>.</h2>
          <p class="section-kicker">
            Freelance design for websites, products, and brands.
          </p>
        </div>
        <a href="services" class="section-link">All services <span class="arrow">↗&#xFE0E;</span></a>
      </div>
      <ul class="capability-directory" aria-label="Capabilities" data-reveal-group>
        {
          capabilityDirectory.map((capability) => (
            <li class={`capability-directory-item capability-directory-item--${capability.tone}`}>
              <span class="capability-directory-mark" aria-hidden="true">{capability.mark}</span>
              <span class="capability-directory-label">{capability.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Selected work -->
  <section class="section" id="work" aria-labelledby="work-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="work-heading">Work for <span class="title-keyword">public services</span>, institutions, and brands.</h2>
          <p class="section-kicker">
            Government platforms, institutional redesigns, and national brand campaigns, including
            my1521, AADE's taxpayer service portal.
          </p>
        </div>
        <a href="work" class="section-link">All work <span class="arrow">↗&#xFE0E;</span></a>
      </div>
      <div class="case-grid">
        <CaseCard cs={featuredWork} />
        {homeWork.map((cs) => <CaseCard cs={cs} />)}
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="section" id="approach" aria-labelledby="approach-heading">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <h2 id="approach-heading">How a brief becomes something <span class="title-keyword">buildable</span>.</h2>
        </div>
        <a href="approach" class="section-link">Full approach <span class="arrow">↗&#xFE0E;</span></a>
      </div>
      <div class="pillar-grid" data-reveal-group>
        {
          approachPillars.map((pillar) => (
            <div class="pillar">
              <span class="num">{pillar.number}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Project fit -->
  <section class="section project-fit" id="project-fit" aria-labelledby="project-fit-heading">
    <div class="container">
      <div class="project-fit-intro" data-reveal>
        <div class="project-fit-head">
          <h2 id="project-fit-heading">
            Bring me in when the work has become <span class="title-keyword">hard to untangle</span>.
          </h2>
          <a href="about" class="section-link">About me <span class="arrow">↗&#xFE0E;</span></a>
        </div>
        <p class="lead">
          A rough brief, a messy current site, or a clear objective is enough to start.
          We can work out what needs to change first.
        </p>
      </div>
      <ul class="project-fit-list" data-reveal-group>
        <li>A <span class="title-keyword">product flow</span> is difficult to use or explain.</li>
        <li>A website has <span class="title-keyword">outgrown</span> its structure or visual direction.</li>
        <li>Your team needs a <span class="title-keyword">Figma system</span> that holds up after handoff.</li>
        <li>A campaign or brand needs <span class="title-keyword">a consistent visual language</span>.</li>
      </ul>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section contact-cta" id="contact" aria-labelledby="contact-heading">
    <div class="cta-media" aria-hidden="true">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="media/cta-poster.jpg"
        src="media/cta-bg.mp4"></video>
    </div>
    <div class="container">
      <h2 id="contact-heading" data-reveal>
        Need to improve a website, product, or <span class="title-keyword">brand system</span>?
      </h2>
      <p class="lead" data-reveal style="--reveal-delay: 1">
        Send the rough version. I can help define the interface, website, or visual system and
        prepare it for the people who will use and maintain it.
      </p>
      <div class="hero-actions" data-reveal style="--reveal-delay: 2">
        <a href="contact" class="btn" data-overlay-trigger data-magnetic>Discuss a project</a>
      </div>
    </div>
  </section>
</Base>
