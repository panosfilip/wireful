---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import { site, skills } from "../data/site";
import profileImage from "../../profile.png";

const strengths = [
  {
    label: "Current role",
    value: "Senior UI/UX Engineer at Choose",
  },
  {
    label: "UI/UX",
    value:
      "Senior-level experience shaping websites, digital services, product interfaces, and design systems",
  },
  {
    label: "Graphic design",
    value:
      "A strong visual foundation across identity, campaigns, editorial design, print, and production",
  },
  {
    label: "Delivery",
    value:
      "Practical understanding of responsive implementation, Figma handoff, WordPress, Elementor, and maintainable content",
  },
  {
    label: "University teaching",
    value:
      "UI design and user-centred methods within Human-Computer Interaction at the University of Athens",
  },
];

---

<Base title={`About | ${site.name}`}>
  <section class="hero hero-inner hero-about">
    <div class="hero-media" aria-hidden="true" data-parallax>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="media/about-hero-poster.jpg"
        src="media/about-hero-bg.mp4"></video>
    </div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 data-intro style="--intro: 1">{site.fullName}.</h1>
        <p class="lead" data-intro style="--intro: 2">
          I’m the designer behind <strong>WIREFUL<span class="tick tick-blink">_</span>, my design
          brand for websites, digital products, and visual systems.</strong>
        </p>
        <p class="lead" data-intro style="--intro: 2">
          I combine UI/UX with a senior graphic design background, content structure, and
          implementation awareness to move work from early direction to a confident handoff. For
          broader scopes, I collaborate with trusted developers, writers, photographers, and
          production partners.
        </p>
        <p class="lead" data-intro style="--intro: 2">
          Alongside my design work, I teach UI design and user-centred methods within
          Human-Computer Interaction at the National and Kapodistrian University of Athens.
        </p>
      </div>
      <div class="hero-portrait" data-intro style="--intro: 1">
        <Image
          src={profileImage}
          alt={`Portrait of ${site.fullName}`}
          widths={[240, 300, 600]}
          sizes="(max-width: 820px) 240px, 300px"
          format="webp"
          quality={88}
          loading="eager"
          fetchpriority="high"
        />
        <span class="hero-portrait-tag" aria-hidden="true">me again</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-strip">
        <div class="about-intro" data-reveal>
          <h2>The short <span class="title-keyword">version</span></h2>
          <div class="prose">
            <p>
              <strong>WIREFUL<span class="tick tick-blink">_</span></strong> starts with the
              wire: structure, flow, and the connections that hold an interface together. I
              work through those before settling the visual direction. For more than ten years,
              I have designed brand identities, websites, campaigns, and digital products for
              agencies, institutions, media brands, hospitality businesses, and independent clients.
            </p>
            <p>
              I'm currently a Senior UI/UX Engineer at Choose, where my day-to-day work includes
              Figma systems, responsive layouts, identity work, UI details, content structure, and
              decisions for WordPress or Elementor builds. That experience keeps my freelance
              work grounded in the practical constraints of implementation, publishing, and handoff.
              I also use AI tools selectively for research synthesis, exploration, and prototyping,
              while keeping the final decisions rooted in the brief and design judgement.
            </p>
            <p>
              At the National and Kapodistrian University of Athens, I teach UI design as part of
              Human-Computer Interaction. My classes connect Figma and interface decisions with
              navigation, usability standards, Think Aloud sessions, focus groups, and other
              user-centred methods.
            </p>
          </div>
        </div>
        <div data-reveal>
          <div class="skill-group">
            <h3>Design & UX</h3>
            <ul class="skill-list">
              {skills.design.map((skill) => (
                <li>
                  <details>
                    <summary><span class="skill-title">{skill.title}</span></summary>
                    <span class="skill-description">{skill.description}</span>
                  </details>
                </li>
              ))}
            </ul>
          </div>
          <div class="skill-group">
            <h3>Tools & delivery</h3>
            <ul class="skill-list">
              {skills.tools.map((skill) => (
                <li>
                  <details>
                    <summary><span class="skill-title">{skill.title}</span></summary>
                    <span class="skill-description">{skill.description}</span>
                  </details>
                </li>
              ))}
            </ul>
          </div>
          <div class="skill-group">
            <h3>Research & methods</h3>
            <ul class="skill-list">
              {skills.research.map((skill) => (
                <li>
                  <details>
                    <summary><span class="skill-title">{skill.title}</span></summary>
                    <span class="skill-description">{skill.description}</span>
                  </details>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 data-reveal>What I bring to the <span class="title-keyword">work</span>.</h2>
      <ul class="fact-list" data-reveal-group>
        {
          strengths.map((strength) => (
            <li>
              <span class="fact-label">{strength.label}</span>
              <span class="fact-value">{strength.value}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section contact-cta">
    <div class="container">
      <h2 data-reveal>Want the <span class="title-keyword">longer version</span>?</h2>
      <p class="lead" data-reveal style="--reveal-delay: 1">
        Explore the portfolio and profile PDFs, or tell me what you’re planning.
      </p>
      <div class="hero-actions" data-reveal style="--reveal-delay: 2">
        <a href="contact" class="btn" data-overlay-trigger data-magnetic>Start a project</a>
        <a href="docs/panagiotis-filippaios-portfolio.pdf" class="btn btn-ghost">
          Portfolio PDF
        </a>
      </div>
    </div>
  </section>
</Base>
