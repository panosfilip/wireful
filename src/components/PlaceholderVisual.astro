---
/**
 * Wireframe-style placeholder cover art, drawn as inline SVG.
 * Each motif suggests the kind of artefact the real screenshot will show:
 * sitemap, search tool, homepage system, campaign landing, or design audit.
 * Swap for a real image by setting cover.type = "image" in caseStudies.ts.
 */
import type { CoverMotif } from "../data/caseStudies";

interface Props {
  motif: CoverMotif;
  alt: string;
}

const { motif, alt } = Astro.props;
---

{
  motif === "sitemap" && (
    <svg viewBox="0 0 640 400" role="img" aria-label={alt} fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="270" y="28" width="100" height="40" rx="4" />
      <path d="M320 68v36M320 104H140v32M320 104h180v32M320 104v32" stroke-dasharray="4 5" />
      <rect x="90" y="136" width="100" height="36" rx="4" />
      <rect x="270" y="136" width="100" height="36" rx="4" stroke="var(--accent)" fill="rgba(233,87,147,0.09)" />
      <rect x="450" y="136" width="100" height="36" rx="4" />
      <path d="M140 172v28M140 200h-46v24M140 200h46v24M320 172v28M320 200h-52v24M320 200h52v24M500 172v28M500 200v24" stroke-dasharray="4 5" />
      <rect x="52" y="224" width="84" height="30" rx="4" />
      <rect x="144" y="224" width="84" height="30" rx="4" />
      <rect x="226" y="224" width="84" height="30" rx="4" stroke="var(--accent)" />
      <rect x="330" y="224" width="84" height="30" rx="4" />
