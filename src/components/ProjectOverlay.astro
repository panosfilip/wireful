---
/**
 * Fullscreen "Start a project" overlay.
 * Left: hero imagery + wordmark. Right: guided request form.
 * Opens from any element carrying [data-overlay-trigger]; those elements keep
 * href="/contact" as the no-JS fallback. Submit composes a pre-filled email.
 */
import { site } from "../data/site";

const projectCapabilities = [
  {
    mark: "WD",
    label: "Website design",
    tone: "violet",
    recommends: ["Brand systems", "WordPress & Elementor"],
  },
  {
    mark: "UI",
    label: "Product UI",
    tone: "rose",
    recommends: ["UX research & audits", "Figma prototypes"],
  },
  {
    mark: "UX",
    label: "UX research & audits",
    tone: "amber",
    recommends: ["Product UI", "Figma prototypes"],
  },
  {
    mark: "FI",
    label: "Figma prototypes",
    tone: "lime",
    recommends: ["Product UI", "UX research & audits"],
  },
  {
    mark: "BR",
    label: "Brand systems",
    tone: "green",
    recommends: ["Website design", "Campaign assets"],
  },
  {
    mark: "CA",
    label: "Campaign assets",
    tone: "cyan",
    recommends: ["Brand systems", "Website design"],
  },
  {
    mark: "WP",
    label: "WordPress & Elementor",
    tone: "blue",
    recommends: ["Website design", "Figma prototypes"],
  },
  {
    mark: "AI",
    label: "AI-assisted workflows",
    tone: "violet",
    recommends: ["Figma prototypes", "UX research & audits"],
  },
  {
    mark: "CO",
    label: "Design consulting",
    tone: "rose",
    recommends: ["UX research & audits", "Product UI"],
  },
];
const budgets = ["Under €2k", "€2k–5k", "€5k–10k", "€10k+", "Not sure yet"];
const timelines = ["As soon as possible", "1–3 months", "Flexible"];
---

<div
  class="project-overlay"
  id="project-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="overlay-title"
  hidden
>
  <div class="overlay-media" aria-hidden="true">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="media/hero-poster.jpg"
      src="media/hero-bg.mp4"></video>
    <div class="overlay-media-copy">
      <p class="wordmark">WIREFUL<span class="tick tick-blink">_</span></p>
      <div>
        <p class="overlay-media-title">Tell me what you want to build.</p>
        <p class="overlay-media-sub">
          A few answers are enough. I read every request and reply with a practical
          next step — usually within two working days.
        </p>
      </div>
    </div>
  </div>

  <div class="overlay-form-panel">
    <div class="overlay-form-head">
      <p class="overlay-form-label" id="overlay-title">
        New project request<span class="tick tick-blink">_</span>
      </p>
      <button class="overlay-close" type="button" aria-label="Close dialog">
        <span class="esc">ESC</span> ✕
      </button>
    </div>

    <form id="project-form" novalidate>
      <fieldset>
        <legend><span class="step">01</span>What can I help with? *</legend>
        <p class="field-hint">Pick everything that feels relevant — you can add detail below.</p>
        <div class="capability-option-grid">
          {
            projectCapabilities.map((capability) => (
              <label class={`capability-option capability-option--${capability.tone}`}>
                <input type="checkbox" name="type" value={capability.label} />
                <span class="capability-option-mark" aria-hidden="true">{capability.mark}</span>
                <span class="capability-option-label">{capability.label}</span>
                <span class="capability-option-remove" aria-hidden="true">✕</span>
              </label>
            ))
          }
        </div>
        <aside
          class="capability-upsell"
          hidden
          aria-live="polite"
          data-capabilities={JSON.stringify(projectCapabilities)}
        >
          <button class="capability-upsell-close" type="button" aria-label="Dismiss suggestions">✕</button>
          <p class="capability-upsell-label">Worth considering alongside this</p>
          <p class="capability-upsell-copy"></p>
          <div class="capability-upsell-options"></div>
        </aside>
        <button class="capability-clear" type="button" hidden>Clear options</button>
        <p class="field-error" data-error="type" role="alert" hidden>Pick at least one thing I can help with.</p>
      </fieldset>

      <fieldset>
        <legend><span class="step">02</span>Budget *</legend>
        <p class="field-hint">A rough range is fine — it helps me suggest the right scope.</p>
        <div class="option-grid">
          {
            budgets.map((budget) => (
              <label class="option">
                <input type="radio" name="budget" value={budget} />
                <span class="box" aria-hidden="true"></span>
                <span class="text">{budget}</span>
              </label>
            ))
          }
        </div>
        <p class="field-error" data-error="budget" role="alert" hidden>Choose a budget range.</p>
      </fieldset>

      <fieldset>
        <legend><span class="step">03</span>Timeline *</legend>
        <div class="option-grid">
          {
            timelines.map((timeline) => (
              <label class="option">
                <input type="radio" name="timeline" value={timeline} />
                <span class="box" aria-hidden="true"></span>
                <span class="text">{timeline}</span>
              </label>
            ))
          }
        </div>
        <p class="field-error" data-error="timeline" role="alert" hidden>Choose a timeline.</p>
      </fieldset>

      <fieldset>
        <legend><span class="step">04</span>About you</legend>
        <div class="field-row">
          <div class="field">
            <label for="pf-name">Name *</label>
            <input id="pf-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="pf-email">Email *</label>
            <input id="pf-email" name="email" type="email" autocomplete="email" required />
          </div>
        </div>
        <div class="field">
          <label for="pf-company">Company / organization</label>
          <input id="pf-company" name="company" type="text" autocomplete="organization" />
        </div>
      </fieldset>

      <fieldset>
        <legend><span class="step">05</span>The brief</legend>
        <div class="field">
          <label for="pf-brief">What are we improving? *</label>
          <textarea
            id="pf-brief"
            name="brief"
            rows="4"
            required
            placeholder="The rough version is enough — what it is, who it's for, what's not working today, links if you have them."></textarea>
        </div>
        <div class="field attachment-field">
          <label for="pf-attachments">Supporting files</label>
          <div class="attachment-picker">
            <input
              id="pf-attachments"
              name="attachments"
              type="file"
              multiple
              accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp"
            />
            <button class="attachment-clear" type="button" hidden>Clear files</button>
          </div>
          <ul class="attachment-list" aria-live="polite" aria-label="Selected files" hidden></ul>
          <p class="field-hint">
            Add briefs, references, or screenshots. Your email app will open next, where you can
            attach the selected files before sending.
          </p>
        </div>
        <label class="option consent-option">
          <input type="checkbox" name="consent" required />
          <span class="box" aria-hidden="true"></span>
          <span class="text">
            I agree that WIREFUL can use my details to respond to this request.
          </span>
        </label>
        <div class="field human-check">
          <label for="pf-human">Quick human check <span class="human-question"></span></label>
          <input
            id="pf-human"
            name="human-check"
            type="number"
            inputmode="numeric"
            autocomplete="off"
            required
          />
        </div>
      </fieldset>

      <div class="overlay-actions">
        <button type="submit" class="btn">Send request ↗&#xFE0E;</button>
        <p class="overlay-alt">
          Prefer plain email? <a href={site.emailHref}>{site.email}</a>
        </p>
      </div>
      <p class="overlay-note" aria-live="polite"></p>
    </form>
  </div>
</div>

<script>
  const overlay = document.getElementById("project-overlay")!;
  const form = document.getElementById("project-form") as HTMLFormElement;
  const closeBtn = overlay.querySelector<HTMLButtonElement>(".overlay-close")!;
  const note = overlay.querySelector<HTMLElement>(".overlay-note")!;
  const capabilityUpsell = overlay.querySelector<HTMLElement>(".capability-upsell")!;
  const capabilityUpsellCopy = overlay.querySelector<HTMLElement>(".capability-upsell-copy")!;
  const capabilityUpsellOptions = overlay.querySelector<HTMLElement>(".capability-upsell-options")!;
  const capabilityUpsellClose = overlay.querySelector<HTMLButtonElement>(".capability-upsell-close")!;
  const capabilityClear = overlay.querySelector<HTMLButtonElement>(".capability-clear")!;
  const attachmentInput = document.getElementById("pf-attachments") as HTMLInputElement;
  const attachmentClear = overlay.querySelector<HTMLButtonElement>(".attachment-clear")!;
  const attachmentList = overlay.querySelector<HTMLUListElement>(".attachment-list")!;
  const humanInput = document.getElementById("pf-human") as HTMLInputElement;
  const humanQuestion = overlay.querySelector<HTMLElement>(".human-question")!;
  const projectCapabilities = JSON.parse(capabilityUpsell.dataset.capabilities ?? "[]") as Array<{
    mark: string;
    label: string;
    tone: string;
    recommends: string[];
  }>;
  const capabilityInputs = Array.from(
    overlay.querySelectorAll<HTMLInputElement>('input[name="type"]'),
  );
  let lastFocused: HTMLElement | null = null;
  let recommendationAccepted = false;
  let addingRecommendation = false;
  let humanAnswer = 0;

  const setHumanCheck = () => {
    const first = Math.floor(Math.random() * 7) + 2;
    const second = Math.floor(Math.random() * 7) + 2;
    humanAnswer = first + second;
    humanQuestion.textContent = `— what is ${first} + ${second}? *`;
    humanInput.value = "";
    humanInput.setCustomValidity("");
  };

  setHumanCheck();

  // Single-choice groups (Budget, Timeline) are optional, so let a second click
  // on the already-selected option clear it — matching the toggle behaviour of
  // the capability checkboxes above. The inputs are pointer-events:none, so the
  // click arrives via the wrapping <label>; we track the checked option per
  // group rather than reading pointer state.
  const checkedByGroup = new Map<string, HTMLInputElement | null>();
  overlay.querySelectorAll<HTMLInputElement>('#project-form input[type="radio"]').forEach((radio) => {
    radio.addEventListener("click", () => {
      if (checkedByGroup.get(radio.name) === radio) {
        radio.checked = false;
        checkedByGroup.set(radio.name, null);
        radio.dispatchEvent(new Event("change", { bubbles: true }));
      } else {
        checkedByGroup.set(radio.name, radio);
      }
    });
  });

  // Steps 01–03 are mandatory but use visually-hidden inputs, so we validate
  // them explicitly with inline messages rather than native required bubbles
  // (which can't anchor to an opacity:0 control). Errors only appear after a
  // first submit attempt, then update live as the user answers each step.
  const stepErrors = {
    type: overlay.querySelector<HTMLElement>('[data-error="type"]')!,
    budget: overlay.querySelector<HTMLElement>('[data-error="budget"]')!,
    timeline: overlay.querySelector<HTMLElement>('[data-error="timeline"]')!,
  };
  type StepKey = keyof typeof stepErrors;
  const stepOrder: StepKey[] = ["type", "budget", "timeline"];
  let submitAttempted = false;

  const isStepInvalid = (key: StepKey) =>
    key === "type"
      ? !capabilityInputs.some((input) => input.checked)
      : !form.querySelector(`input[name="${key}"]:checked`);

  const refreshStepError = (key: StepKey) => {
    stepErrors[key].hidden = !isStepInvalid(key);
  };

  const revalidateIfAttempted = (key: StepKey) => {
    if (submitAttempted) refreshStepError(key);
  };

  const focusStep = (key: StepKey) => {
    stepErrors[key].closest("fieldset")?.scrollIntoView({ behavior: "smooth", block: "start" });
    const first =
      key === "type"
        ? capabilityInputs[0]
        : form.querySelector<HTMLInputElement>(`input[name="${key}"]`);
    first?.focus({ preventScroll: true });
  };

  overlay
    .querySelectorAll<HTMLInputElement>('#project-form input[name="budget"], #project-form input[name="timeline"]')
    .forEach((radio) => radio.addEventListener("change", () => revalidateIfAttempted(radio.name as StepKey)));

  const capabilityByLabel = new Map(projectCapabilities.map((capability) => [capability.label, capability]));

  const updateCapabilityUpsell = () => {
    const selected = new Set(capabilityInputs.filter((input) => input.checked).map((input) => input.value));
    capabilityClear.hidden = selected.size === 0;
    const recommended = [...selected]
      .flatMap((label) => capabilityByLabel.get(label)?.recommends ?? [])
      .filter((label, index, list) => !selected.has(label) && list.indexOf(label) === index)
      .slice(0, 2);

    overlay.querySelectorAll<HTMLElement>(".capability-option").forEach((option) => {
      const input = option.querySelector<HTMLInputElement>('input[name="type"]');
      option.classList.toggle("is-recommended", input !== null && recommended.includes(input.value));
    });

    if (recommendationAccepted || !recommended.length) {
      capabilityUpsell.hidden = true;
      overlay.querySelectorAll(".capability-option").forEach((option) => {
        option.classList.remove("is-recommended");
      });
      return;
    }

    capabilityUpsell.hidden = false;
    capabilityUpsellCopy.textContent =
      recommended.length > 1
        ? "These additions often make the work more coherent from first impression to launch."
        : "This is a natural complement to the work you selected.";
    capabilityUpsellOptions.replaceChildren(
      ...recommended.map((label) => {
        const capability = capabilityByLabel.get(label)!;
        const button = document.createElement("button");
        button.type = "button";
        button.className = "capability-upsell-option";
        button.dataset.addCapability = label;

        const mark = document.createElement("span");
        mark.className = `capability-upsell-mark capability-option--${capability.tone}`;
        mark.textContent = capability.mark;
        mark.setAttribute("aria-hidden", "true");

        const text = document.createElement("span");
        text.textContent = `Add ${label}`;
        button.append(mark, text);
        return button;
      }),
    );
  };

  capabilityInputs.forEach((input) =>
    input.addEventListener("change", () => {
      if (!addingRecommendation) recommendationAccepted = false;
      updateCapabilityUpsell();
      revalidateIfAttempted("type");
    }),
  );
  capabilityUpsellClose.addEventListener("click", () => {
    recommendationAccepted = true;
    updateCapabilityUpsell();
  });
  capabilityUpsellOptions.addEventListener("click", (event) => {
    const target = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-add-capability]");
    if (!target) return;
    const input = capabilityInputs.find((capability) => capability.value === target.dataset.addCapability);
    if (!input) return;
    recommendationAccepted = true;
    addingRecommendation = true;
    input.checked = true;
    input.dispatchEvent(new Event("change", { bubbles: true }));
    addingRecommendation = false;
    input.focus();
  });
  capabilityClear.addEventListener("click", () => {
    capabilityInputs.forEach((input) => {
      input.checked = false;
    });
    recommendationAccepted = false;
    updateCapabilityUpsell();
    revalidateIfAttempted("type");
    capabilityInputs[0]?.focus();
  });

  const formatFileSize = (bytes: number) => {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  };

  const updateAttachments = () => {
    const files = Array.from(attachmentInput.files ?? []);
    attachmentClear.hidden = files.length === 0;
    attachmentList.hidden = files.length === 0;
    attachmentList.replaceChildren(
      ...files.map((file) => {
        const item = document.createElement("li");
        item.className = "attachment-item";

        const extension = file.name.includes(".") ? file.name.split(".").pop()!.toUpperCase() : "FILE";
        const type = document.createElement("span");
        type.className = "attachment-item-type";
        type.textContent = extension;
        type.setAttribute("aria-hidden", "true");

        const name = document.createElement("span");
        name.className = "attachment-item-name";
        name.textContent = file.name;

        const size = document.createElement("span");
        size.className = "attachment-item-size";
        size.textContent = formatFileSize(file.size);
        item.append(type, name, size);
        return item;
      }),
    );
  };

  attachmentInput.addEventListener("change", updateAttachments);
  attachmentClear.addEventListener("click", () => {
    attachmentInput.value = "";
    updateAttachments();
    attachmentInput.focus();
  });

  const focusables = () =>
    Array.from(
      overlay.querySelectorAll<HTMLElement>(
        'button, input, textarea, a[href], [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((el) => el.offsetParent !== null);

  const open = () => {
    lastFocused = document.activeElement as HTMLElement;
    overlay.hidden = false;
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      overlay.classList.add("is-open");
      setHumanCheck();
      overlay.querySelector<HTMLElement>("input, button")?.focus();
    });
  };

  const close = () => {
    overlay.classList.remove("is-open");
    document.body.style.overflow = "";
    window.setTimeout(() => {
      overlay.hidden = true;
    }, 350);
    lastFocused?.focus();
  };

  document.querySelectorAll<HTMLElement>("[data-overlay-trigger]").forEach((el) => {
    el.addEventListener("click", (event) => {
      event.preventDefault();
      open();
    });
  });

  closeBtn.addEventListener("click", close);

  document.addEventListener("keydown", (event) => {
    if (overlay.hidden) return;
    if (event.key === "Escape") {
      close();
      return;
    }
    // Minimal focus trap
    if (event.key === "Tab") {
      const els = focusables();
      if (!els.length) return;
      const first = els[0];
      const last = els[els.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }
  });

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    submitAttempted = true;

    // Mandatory choice steps (01–03) first, top to bottom.
    stepOrder.forEach(refreshStepError);
    const firstInvalidStep = stepOrder.find(isStepInvalid);
    if (firstInvalidStep) {
      focusStep(firstInvalidStep);
      return;
    }

    // Then the native fields (name, email, brief, consent) and human check.
    if (Number(humanInput.value) !== humanAnswer) {
      humanInput.setCustomValidity("Please answer the human check before sending your request.");
      humanInput.reportValidity();
      return;
    }
    humanInput.setCustomValidity("");
    if (!form.reportValidity()) return;

    // TODO: submit to a real form endpoint. For now the request is validated
    // client-side and acknowledged — no email client is opened.
    note.textContent =
      "Thanks — your request looks complete. Sending isn't wired up yet, so nothing has been submitted; the form endpoint is coming soon.";
  });
</script>
