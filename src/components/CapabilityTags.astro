---
import { type ProjectTag } from "../data/projectTags";
import CapabilityTag from "./CapabilityTag.astro";

interface Props {
  tags: ProjectTag[];
  variant?: "card" | "detail";
  /**
   * When set, tokens are split into independent rows of this many. Each row is
   * its own flex track, so a hover reveal only reshapes its own row and never
   * shifts the other rows (a shared grid would couple them). Used on the
   * case-study meta — see the .capability-tags--rows rule in global.css.
   */
  perRow?: number;
}

const { tags, variant = "card", perRow } = Astro.props;

const rows = perRow
  ? Array.from({ length: Math.ceil(tags.length / perRow) }, (_, i) =>
      tags.slice(i * perRow, i * perRow + perRow),
    )
  : null;
---

{
  rows ? (
    <div
      class={`capability-tags capability-tags--${variant} capability-tags--rows`}
      role="group"
      aria-label="Project tags"
    >
      {rows.map((row) => (
        <ul class="capability-tags-row" role="list">
          {row.map((tag) => (
            <CapabilityTag tag={tag} />
          ))}
        </ul>
      ))}
    </div>
  ) : (
    <ul class={`capability-tags capability-tags--${variant}`} aria-label="Project tags">
      {tags.map((tag) => (
        <CapabilityTag tag={tag} />
      ))}
    </ul>
  )
}

<script>
  const capabilityTags = Array.from(document.querySelectorAll<HTMLElement>("[data-capability-tag]"));
  const isTouchInterface = window.matchMedia("(hover: none) and (pointer: coarse)");

  const collapseTags = () => {
    capabilityTags.forEach((tag) => {
      tag.classList.remove("is-expanded");
      tag.setAttribute("aria-expanded", "false");
    });
  };

  capabilityTags.forEach((tag) => {
    tag.addEventListener("click", (event) => {
      if (!isTouchInterface.matches) return;
      event.preventDefault();
      event.stopPropagation();

      if (tag.classList.contains("is-expanded")) {
        window.location.href = new URL(
          `work?tag=${tag.dataset.capabilityTag}#taxonomy`,
          document.baseURI,
        ).href;
        return;
      }

      collapseTags();
      tag.classList.add("is-expanded");
      tag.setAttribute("aria-expanded", "true");
    });
  });
</script>
