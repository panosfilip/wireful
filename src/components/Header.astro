---
import ContactIcons from "./ContactIcons.astro";

const base = `${import.meta.env.BASE_URL}/`;
const path = Astro.url.pathname.replace(/\/$/, "") || base;
const links = [
  { href: `${base}approach`, label: "Approach" },
  { href: `${base}work`, label: "Work" },
  { href: `${base}services`, label: "Services" },
  { href: `${base}about`, label: "About" },
  { href: `${base}contact`, label: "Contact" },
];
const isActive = (href: string) => {
  const normalizedHref = href.replace(/\/$/, "");
  return path === normalizedHref || path.startsWith(normalizedHref + "/");
};
---

<header class="site-header" id="site-header">
  <div class="header-shell">
    <div class="container header-inner">
      <a href={base} class="wordmark" data-magnetic aria-label="WIREFUL home">
        WIREFUL<span class="tick tick-blink">_</span>
      </a>
      <nav class="primary-nav" id="primary-nav" aria-label="Primary">
        <ul>
          {
            links.map((link, index) => (
              <li style={`--nav-i: ${index}`}>
                <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        {/* Only rendered visible inside the fullscreen mobile overlay */}
        <div class="nav-overlay-foot">
          <ContactIcons variant="header" />
        </div>
      </nav>
      <div class="header-actions">
        <button
          type="button"
          class="theme-toggle"
          aria-label="Switch to light mode"
          aria-pressed="false"
          title="Switch to light mode"
        >
          <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="3.5"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.2 15.1A8.7 8.7 0 0 1 8.9 3.8 8.7 8.7 0 1 0 20.2 15.1Z"></path>
          </svg>
        </button>
        <ContactIcons variant="header" />
        <a href="contact" class="btn btn-small" data-overlay-trigger data-magnetic><span>Start a project</span></a>
        <button
          type="button"
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="primary-nav"
          aria-label="Menu"
        >
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")!;
  const toggle = header.querySelector<HTMLButtonElement>(".nav-toggle")!;
  const nav = header.querySelector<HTMLElement>(".primary-nav")!;
  const themeToggle = header.querySelector<HTMLButtonElement>(".theme-toggle")!;

  // Feedback click for the theme toggle (0.4s mono mp3, ~2KB). Created
  // eagerly so the first toggle isn't late while the file fetches; volume
  // kept low so it reads as feedback, not an event. play() is fired in the
  // click handler, so autoplay policy is always satisfied; the catch covers
  // the edge cases (interrupted load, muted contexts).
  const toggleSound = new Audio(`${import.meta.env.BASE_URL}/media/ui-theme-toggle.mp3`);
  toggleSound.preload = "auto";
  toggleSound.volume = 0.45;
  const playToggleSound = () => {
    toggleSound.currentTime = 0;
    toggleSound.play().catch(() => {});
  };

  const updateThemeControl = () => {
    const isLight = document.documentElement.dataset.theme === "light";
    const label = `Switch to ${isLight ? "dark" : "light"} mode`;
    themeToggle.setAttribute("aria-label", label);
    themeToggle.setAttribute("aria-pressed", String(isLight));
    themeToggle.title = label;
  };

  updateThemeControl();
  themeToggle.addEventListener("click", () => {
    playToggleSound();
    const theme = document.documentElement.dataset.theme === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;
    // The hex values live in data attributes on the meta tag (src/data/theme.ts).
    const themeMeta = document.querySelector<HTMLMetaElement>("#theme-color");
    const color = themeMeta?.dataset[theme];
    if (themeMeta && color) themeMeta.setAttribute("content", color);
    try {
      localStorage.setItem("wireful-theme", theme);
    } catch {
      // The theme still works for this page when storage is unavailable.
    }
    updateThemeControl();
  });

  const setOpen = (open: boolean) => {
    header.classList.toggle("nav-open", open);
    toggle.setAttribute("aria-expanded", String(open));
    // The mobile menu covers the viewport, so the page must not scroll under it
    document.documentElement.classList.toggle("nav-locked", open);
  };

  // Leaving the mobile breakpoint hides the overlay via CSS; drop the state
  // (and the scroll lock) with it.
  const mobileNav = window.matchMedia("(max-width: 620px)");
  mobileNav.addEventListener("change", (event) => {
    if (!event.matches) setOpen(false);
  });

  toggle.addEventListener("click", () => {
    setOpen(!header.classList.contains("nav-open"));
  });

  // Close when a link is chosen, on Escape, or when tapping outside the header
  nav.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).closest("a")) setOpen(false);
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && header.classList.contains("nav-open")) {
      setOpen(false);
      toggle.focus();
    }
  });
  document.addEventListener("click", (event) => {
    if (header.classList.contains("nav-open") && !header.contains(event.target as Node)) {
      setOpen(false);
    }
  });
</script>
