---
import { site } from "../data/site";
import ContactIcons from "./ContactIcons.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <a href="/contact" class="footer-contact-link" data-reveal>
      Have a brief that deserves better design? <span class="arrow">↗</span>
    </a>
    <div class="footer-grid">
      <div class="col">
        <h3>Navigate</h3>
        <ul>
          <li><a href="/work">Work</a></li>
          <li><a href="/approach">Approach</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="col">
        <h3>Contact</h3>
        <ContactIcons variant="footer" />
        <p class="muted footer-location">{site.location}</p>
      </div>
      <div class="col">
        <h3>Elsewhere</h3>
        <ul>
          {
            site.socials.map((s) => (
              <li>
                <a href={s.href} title={s.note}>
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <p class="footer-wordmark" aria-hidden="true">WIREFUL<span class="tick tick-blink">_</span></p>
    <div class="footer-bottom">
      <span>© {year} {site.fullName}</span>
      <a href="#top" class="back-to-top">Back to top ↑</a>
    </div>
  </div>
</footer>
